@model FortuneInternalData.Web.ViewModels.ChangeOwnPasswordViewModel
@{
    ViewData["Title"] = "Change Password";
}

<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
        <div class="card stat-card">
            <div class="card-header bg-white">
                <h4 class="mb-0"><i class="bi bi-lock-fill"></i> Change Password</h4>
            </div>
            <div class="card-body p-4">
                <form method="post" asp-action="ChangeOwnPassword">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="All" class="alert alert-danger" style="display: @(ViewData.ModelState.ErrorCount > 0 ? "block" : "none")"></div>

                    <div class="mb-3">
                        <label asp-for="CurrentPassword" class="form-label">Current Password <span class="text-danger">*</span></label>
                        <input asp-for="CurrentPassword" class="form-control" type="password" />
                        <span asp-validation-for="CurrentPassword" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="NewPassword" class="form-label">New Password <span class="text-danger">*</span></label>
                        <input asp-for="NewPassword" class="form-control" type="password" />
                        <div class="form-text">Min 8 chars: uppercase, lowercase, digit, and special character.</div>
                        <span asp-validation-for="NewPassword" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="ConfirmPassword" class="form-label">Confirm Password <span class="text-danger">*</span></label>
                        <input asp-for="ConfirmPassword" class="form-control" type="password" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary flex-grow-1">
                            <i class="bi bi-check-circle"></i> Change Password
                        </button>
                        <a href="/Dashboard" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
