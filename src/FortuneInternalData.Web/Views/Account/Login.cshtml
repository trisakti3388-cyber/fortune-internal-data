@model FortuneInternalData.Web.ViewModels.LoginViewModel

<div class="card">
    <h2>Login</h2>
    <form method="post">
        <div>
            <label>Email</label><br />
            <input asp-for="Email" />
        </div>
        <div>
            <label>Password</label><br />
            <input asp-for="Password" type="password" />
        </div>
        <div>
            <label><input asp-for="RememberMe" type="checkbox" /> Remember me</label>
        </div>
        <button type="submit">Login</button>
    </form>
</div>
