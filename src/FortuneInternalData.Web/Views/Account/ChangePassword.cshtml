@model FortuneInternalData.Web.ViewModels.ChangePasswordViewModel
@{
    ViewData["Title"] = "Change Password";
}

<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
        <div class="card stat-card">
            <div class="card-header bg-white">
                <h4 class="mb-0"><i class="bi bi-lock-fill"></i> Change Password Required</h4>
            </div>
            <div class="card-body p-4">
                <div class="alert alert-warning">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    Your password has been reset by an administrator. Please set a new password before continuing.
                </div>

                <form method="post" asp-action="ChangePassword">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="All" class="alert alert-danger" style="display: @(ViewData.ModelState.ErrorCount > 0 ? "block" : "none")"></div>

                    <div class="mb-3">
                        <label asp-for="NewPassword" class="form-label">New Password <span class="text-danger">*</span></label>
                        <input asp-for="NewPassword" class="form-control" type="password" />
                        <div class="form-text">Min 8 chars: uppercase, lowercase, digit, and special character.</div>
                        <span asp-validation-for="NewPassword" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="ConfirmPassword" class="form-label">Confirm Password <span class="text-danger">*</span></label>
                        <input asp-for="ConfirmPassword" class="form-control" type="password" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>

                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-check-circle"></i> Set New Password
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
