@model FortuneInternalData.Application.DTOs.WebSummaryDto
@{
    ViewData["Title"] = "Web Status Summary";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-globe"></i> Web Status Summary</h2>
    <div class="d-flex gap-2">
        <span class="text-muted align-self-center">Total Records: <strong>@Model.TotalRecords.ToString("N0")</strong></span>
        <a href="/WebSummary/Export" class="btn btn-success">
            <i class="bi bi-file-earmark-excel"></i> Export Excel
        </a>
    </div>
</div>

<div class="row mb-4">
    <div class="col-12">
        <div class="card stat-card">
            <div class="card-header bg-white">
                <h5 class="mb-0"><i class="bi bi-bar-chart-fill text-info"></i> YES Count per Web Column</h5>
            </div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr>
                                <th>Column</th>
                                <th class="text-success">YES</th>
                                <th class="text-danger">NO</th>
                                <th class="text-muted">NULL / Empty</th>
                                <th>YES %</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var col in Model.Columns)
                            {
                                var total = col.YesCount + col.NoCount + col.NullCount;
                                var yesPct = total > 0 ? (double)col.YesCount / total * 100 : 0;
                                <tr>
                                    <td><span class="badge bg-secondary">@col.ColumnName</span></td>
                                    <td><span class="fw-bold text-success">@col.YesCount.ToString("N0")</span></td>
                                    <td><span class="text-danger">@col.NoCount.ToString("N0")</span></td>
                                    <td><span class="text-muted">@col.NullCount.ToString("N0")</span></td>
                                    <td>
                                        <div class="d-flex align-items-center gap-2">
                                            <div class="progress flex-grow-1" style="height:8px; min-width:80px;">
                                                <div class="progress-bar bg-success" style="width:@yesPct.ToString("F1")%"></div>
                                            </div>
                                            <span class="text-muted small">@yesPct.ToString("F1")%</span>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-6">
        <div class="card stat-card">
            <div class="card-header bg-white">
                <h5 class="mb-0"><i class="bi bi-pie-chart-fill text-primary"></i> Distribution (how many webs active per number)</h5>
            </div>
            <div class="card-body p-0">
                <table class="table table-hover mb-0">
                    <thead>
                        <tr>
                            <th>Webs Active</th>
                            <th>Number Count</th>
                            <th>% of Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var dist in Model.Distribution)
                        {
                            var pct = Model.TotalRecords > 0 ? (double)dist.NumberCount / Model.TotalRecords * 100 : 0;
                            <tr>
                                <td>
                                    @if (dist.WebCount == 0)
                                    {
                                        <span class="badge bg-secondary">0 webs</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success">@dist.WebCount web@(dist.WebCount == 1 ? "" : "s")</span>
                                    }
                                </td>
                                <td><strong>@dist.NumberCount.ToString("N0")</strong></td>
                                <td>
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="progress flex-grow-1" style="height:8px; min-width:80px;">
                                            <div class="progress-bar bg-primary" style="width:@pct.ToString("F1")%"></div>
                                        </div>
                                        <span class="text-muted small">@pct.ToString("F1")%</span>
                                    </div>
                                </td>
                            </tr>
                        }
                        @if (!Model.Distribution.Any())
                        {
                            <tr><td colspan="3" class="text-center text-muted py-4">No data available.</td></tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card stat-card">
            <div class="card-header bg-white">
                <h5 class="mb-0"><i class="bi bi-grid-3x3-gap-fill text-warning"></i> Quick Stats</h5>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    @{
                        var totalYes = Model.Columns.Sum(c => c.YesCount);
                        var totalWithAnyWeb = Model.Distribution.Where(d => d.WebCount > 0).Sum(d => d.NumberCount);
                        var totalNoWeb = Model.Distribution.FirstOrDefault(d => d.WebCount == 0)?.NumberCount ?? 0;
                    }
                    <div class="col-6">
                        <div class="bg-light rounded p-3 text-center">
                            <div class="fs-4 fw-bold text-success">@totalYes.ToString("N0")</div>
                            <div class="text-muted small">Total YES across all webs</div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="bg-light rounded p-3 text-center">
                            <div class="fs-4 fw-bold text-primary">@totalWithAnyWeb.ToString("N0")</div>
                            <div class="text-muted small">Numbers with at least 1 web</div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="bg-light rounded p-3 text-center">
                            <div class="fs-4 fw-bold text-secondary">@totalNoWeb.ToString("N0")</div>
                            <div class="text-muted small">Numbers with no webs</div>
                        </div>
                    </div>
                    <div class="col-6">
                        <div class="bg-light rounded p-3 text-center">
                            <div class="fs-4 fw-bold text-info">@Model.TotalRecords.ToString("N0")</div>
                            <div class="text-muted small">Total records</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
