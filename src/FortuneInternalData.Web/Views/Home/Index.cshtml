@{
    ViewData["Title"] = "Welcome";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-8 col-lg-6 text-center">
        <div class="card stat-card p-5">
            <i class="bi bi-database-fill text-primary" style="font-size: 4rem;"></i>
            <h1 class="mt-3">Fortune Internal Data</h1>
            <p class="text-muted fs-5">Internal phone data storage and management platform.</p>
            <div class="mt-4">
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a class="btn btn-primary btn-lg" href="/Dashboard">
                        <i class="bi bi-speedometer2"></i> Go to Dashboard
                    </a>
                }
                else
                {
                    <a class="btn btn-primary btn-lg" href="/Account/Login">
                        <i class="bi bi-box-arrow-in-right"></i> Sign In
                    </a>
                }
            </div>
        </div>
    </div>
</div>
