@model FortuneInternalData.Web.ViewModels.ImportHistoryViewModel
@using FortuneInternalData.Web.Extensions
@{
    ViewData["Title"] = "Import History";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-clock-history"></i> Import History</h2>
    @if (User.IsInRole("Superadmin") || User.IsInRole("Admin"))
    {
        <div class="d-flex gap-2">
            <a href="/Imports/Create" class="btn btn-primary"><i class="bi bi-upload"></i> Upload Import</a>
            <a href="/Imports/CreateUpdate" class="btn btn-warning"><i class="bi bi-arrow-repeat"></i> Update Import</a>
            <a href="/Imports/CreateDelete" class="btn btn-danger"><i class="bi bi-trash"></i> Delete Import</a>
            <a href="/Imports/CreateWebStatus" class="btn btn-info text-white"><i class="bi bi-globe"></i> Web Status</a>
        </div>
    }
</div>

<div class="card stat-card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>#</th>
                    <th>File Name</th>
                    <th>Type</th>
                    <th>Uploaded By</th>
                    <th>Status</th>
                    <th>Total</th>
                    <th>New</th>
                    <th>Existing</th>
                    <th>Invalid</th>
                    <th>Duplicate</th>
                    <th>Date</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Items.Any())
                {
                    foreach (var item in Model.Items)
                    {
                        var typeBadge = item.BatchType switch
                        {
                            "update" => "bg-warning text-dark",
                            "delete" => "bg-danger",
                            "web_status" => "bg-info text-dark",
                            _ => "bg-primary"
                        };
                        var typeIcon = item.BatchType switch
                        {
                            "update" => "bi-arrow-repeat",
                            "delete" => "bi-trash",
                            "web_status" => "bi-globe",
                            _ => "bi-upload"
                        };
                        <tr>
                            <td>@item.Id</td>
                            <td>@item.FileName</td>
                            <td>
                                <span class="badge @typeBadge">
                                    <i class="bi @typeIcon"></i> @item.BatchType
                                </span>
                            </td>
                            <td>@item.UploadedByName</td>
                            <td><span class="badge badge-@item.Status">@item.Status</span></td>
                            <td>@item.TotalRows</td>
                            <td><span class="text-success fw-bold">@item.NewRows</span></td>
                            <td><span class="text-warning">@item.ExistingRows</span></td>
                            <td><span class="text-danger">@item.InvalidRows</span></td>
                            <td><span class="text-purple">@item.DuplicateRows</span></td>
                            <td class="text-muted small">@item.CreatedAt.ToJakartaDisplay()</td>
                            <td>
                                <a href="/Imports/Detail/@item.Id" class="btn btn-outline-primary btn-sm">
                                    <i class="bi bi-eye"></i> Detail
                                </a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="12" class="text-center text-muted py-4">No import history found.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>
