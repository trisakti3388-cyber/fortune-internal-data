@model FortuneInternalData.Web.ViewModels.UploadImportViewModel
@{
    ViewData["Title"] = "Delete Import";
}

<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card stat-card">
            <div class="card-header bg-white">
                <h4 class="mb-0"><i class="bi bi-trash text-danger"></i> Delete Import</h4>
            </div>
            <div class="card-body p-4">
                <div class="alert alert-danger">
                    <i class="bi bi-exclamation-triangle-fill"></i>
                    <strong>Delete Import</strong> — Upload a CSV or XLSX file with a <code>phone_number</code> column.
                    Existing records matching those phone numbers will be <strong>permanently deleted</strong> from the database.
                    This action cannot be undone. Review the preview carefully before confirming.
                </div>

                <form method="post" enctype="multipart/form-data" asp-action="CreateDelete">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="All" class="alert alert-danger" style="display: @(ViewData.ModelState.ErrorCount > 0 ? "block" : "none")"></div>

                    <div class="mb-4">
                        <label class="form-label fw-semibold">Select File</label>
                        <input asp-for="File" type="file" class="form-control" accept=".csv,.xlsx" />
                        <div class="form-text">Accepted: CSV (.csv) or Excel (.xlsx). Required column: <code>phone_number</code></div>
                        <span asp-validation-for="File" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-danger fw-bold">
                            <i class="bi bi-cloud-upload"></i> Upload &amp; Process
                        </button>
                        <a href="/Imports" class="btn btn-outline-secondary">Cancel</a>
                        <a href="/Imports/DownloadDeleteTemplate" class="btn btn-outline-success ms-auto">
                            <i class="bi bi-file-earmark-arrow-down"></i> Download Template
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
