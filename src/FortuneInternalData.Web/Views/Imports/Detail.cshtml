@model FortuneInternalData.Web.ViewModels.ImportBatchDetailViewModel

@if (Model.Batch is null)
{
    <div class="card"><p class="muted">Import batch not found.</p></div>
}
else
{
    <div class="card">
        <h2>Import Batch Detail</h2>
        <p><strong>Batch ID:</strong> @Model.Batch.BatchId</p>
        <p><strong>File Name:</strong> @Model.Batch.FileName</p>
        <p><strong>Uploaded By:</strong> @Model.Batch.UploadedByName</p>
        <p><strong>Status:</strong> @Model.Batch.Status</p>
        <p><strong>Created At:</strong> @Model.Batch.CreatedAt</p>
        <form method="post" action="/Imports/Confirm">
            <input type="hidden" name="batchId" value="@Model.Batch.BatchId" />
            <button type="submit">Confirm Import</button>
        </form>
    </div>

    <div class="card">
        <h3>Summary</h3>
        <ul>
            <li>Total Rows: @Model.Batch.Summary.TotalRows</li>
            <li>New Rows: @Model.Batch.Summary.NewRows</li>
            <li>Existing Rows: @Model.Batch.Summary.ExistingRows</li>
            <li>Invalid Rows: @Model.Batch.Summary.InvalidRows</li>
            <li>Duplicate Rows: @Model.Batch.Summary.DuplicateRows</li>
        </ul>
    </div>

    <table>
        <thead>
            <tr>
                <th>Seq</th>
                <th>Raw Phone</th>
                <th>Normalized</th>
                <th>Remark</th>
                <th>Status</th>
                <th>Message</th>
            </tr>
        </thead>
        <tbody>
        @if (Model.Batch.Rows.Any())
        {
            foreach (var row in Model.Batch.Rows)
            {
                <tr>
                    <td>@row.Seq</td>
                    <td>@row.RawPhoneNumber</td>
                    <td>@row.NormalizedPhoneNumber</td>
                    <td>@row.Remark</td>
                    <td>@row.RowStatus</td>
                    <td>@row.Message</td>
                </tr>
            }
        }
        else
        {
            <tr><td colspan="6" class="muted">No row detail found.</td></tr>
        }
        </tbody>
    </table>
}
