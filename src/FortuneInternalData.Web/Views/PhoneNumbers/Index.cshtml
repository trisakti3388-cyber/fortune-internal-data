@model FortuneInternalData.Web.ViewModels.PhoneNumberListViewModel
@using FortuneInternalData.Domain.Constants
@{
    ViewData["Title"] = "Phone Data";
    var totalPages = Model.Result.TotalCount > 0 ? (int)Math.Ceiling((double)Model.Result.TotalCount / Model.PageSize) : 1;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-telephone-fill"></i> Phone Data</h2>
    <span class="text-muted">@Model.Result.TotalCount.ToString("N0") records</span>
</div>

<div class="card stat-card mb-4">
    <div class="card-body">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-md-3">
                <label class="form-label small">Phone Number</label>
                <input name="SearchPhoneNumber" value="@Model.SearchPhoneNumber" class="form-control" placeholder="Search phone number" />
            </div>
            <div class="col-md-2">
                <label class="form-label small">Status</label>
                <select name="Status" class="form-select">
                    <option value="">All Statuses</option>
                    @foreach (var s in PhoneStatuses.All)
                    {
                        <option value="@s" selected="@(Model.Status == s)">@s</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label small">WhatsApp Status</label>
                <select name="WhatsappStatus" class="form-select">
                    <option value="">All</option>
                    @foreach (var s in WhatsappStatuses.All)
                    {
                        <option value="@s" selected="@(Model.WhatsappStatus == s)">@s</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label small">Per Page</label>
                <select name="PageSize" class="form-select">
                    @foreach (var ps in new[] { 20, 50, 100 })
                    {
                        <option value="@ps" selected="@(Model.PageSize == ps)">@ps</option>
                    }
                </select>
            </div>
            <div class="col-md-3">
                <button type="submit" class="btn btn-primary"><i class="bi bi-search"></i> Search</button>
                <a href="/PhoneNumbers" class="btn btn-outline-secondary">Clear</a>
            </div>
            <input type="hidden" name="Page" value="1" />
        </form>
    </div>
</div>

<div class="card stat-card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Seq</th>
                    <th>Phone Number</th>
                    <th>Status</th>
                    <th>WhatsApp</th>
                    <th>Remark</th>
                    <th>Upload Date</th>
                    <th>Modified</th>
                    <th>Action</th>
                </tr>
            </thead>
            <tbody>
                @if (Model.Result.Items.Any())
                {
                    var idx = (Model.Page - 1) * Model.PageSize;
                    foreach (var item in Model.Result.Items)
                    {
                        idx++;
                        <tr>
                            <td class="text-muted">@idx</td>
                            <td>@item.Seq</td>
                            <td><code>@item.PhoneNumber</code></td>
                            <td>
                                <span class="badge @(item.Status == "active" ? "bg-success" : "bg-secondary")">@item.Status</span>
                            </td>
                            <td>
                                @if (!string.IsNullOrEmpty(item.WhatsappStatus))
                                {
                                    <span class="badge bg-info text-dark">@item.WhatsappStatus</span>
                                }
                            </td>
                            <td>@(item.Remark != null && item.Remark.Length > 30 ? item.Remark[..30] + "..." : item.Remark)</td>
                            <td class="text-muted small">@item.UploadDate?.ToString("yyyy-MM-dd")</td>
                            <td class="text-muted small">@item.ModifiedDate?.ToString("yyyy-MM-dd HH:mm")</td>
                            <td>
                                <a href="/PhoneNumbers/Edit/@item.Id" class="btn btn-outline-primary btn-sm">
                                    <i class="bi bi-pencil"></i> Edit
                                </a>
                            </td>
                        </tr>
                    }
                }
                else
                {
                    <tr><td colspan="9" class="text-center text-muted py-4">No records found.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

@if (totalPages > 1)
{
    <nav class="mt-3">
        <ul class="pagination justify-content-center">
            @if (Model.Page > 1)
            {
                <li class="page-item">
                    <a class="page-link" href="/PhoneNumbers?SearchPhoneNumber=@Model.SearchPhoneNumber&Status=@Model.Status&WhatsappStatus=@Model.WhatsappStatus&Page=@(Model.Page - 1)&PageSize=@Model.PageSize">&laquo; Prev</a>
                </li>
            }
            @for (int i = Math.Max(1, Model.Page - 2); i <= Math.Min(totalPages, Model.Page + 2); i++)
            {
                <li class="page-item @(i == Model.Page ? "active" : "")">
                    <a class="page-link" href="/PhoneNumbers?SearchPhoneNumber=@Model.SearchPhoneNumber&Status=@Model.Status&WhatsappStatus=@Model.WhatsappStatus&Page=@i&PageSize=@Model.PageSize">@i</a>
                </li>
            }
            @if (Model.Page < totalPages)
            {
                <li class="page-item">
                    <a class="page-link" href="/PhoneNumbers?SearchPhoneNumber=@Model.SearchPhoneNumber&Status=@Model.Status&WhatsappStatus=@Model.WhatsappStatus&Page=@(Model.Page + 1)&PageSize=@Model.PageSize">Next &raquo;</a>
                </li>
            }
        </ul>
    </nav>
}
