@model FortuneInternalData.Web.ViewModels.PhoneNumberListViewModel
@using FortuneInternalData.Domain.Constants
@using FortuneInternalData.Web.Extensions
@using Microsoft.AspNetCore.Authorization
@inject IAuthorizationService AuthorizationService
@inject FortuneInternalData.Application.Interfaces.IPermissionService PermissionService
@{
    ViewData["Title"] = "Phone Data";
    var totalPages = Model.Result.TotalCount > 0 ? (int)Math.Ceiling((double)Model.Result.TotalCount / Model.PageSize) : 1;
    var isAdminOrAbove = (await AuthorizationService.AuthorizeAsync(User, FortuneInternalData.Web.Security.PolicyNames.AdminOrAbove)).Succeeded;
    var isSuperadmin = User.IsInRole("Superadmin");
    var dateFromStr = Model.DateFrom.HasValue ? Model.DateFrom.Value.ToString("yyyy-MM-dd") : "";
    var dateToStr = Model.DateTo.HasValue ? Model.DateTo.Value.ToString("yyyy-MM-dd") : "";
    var searchRef = Model.SearchReference ?? "";
    var searchAgent = Model.SearchAgentName ?? "";

    var userRoleClaim = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? string.Empty;
    var canExport = await PermissionService.HasExportPermissionAsync(userRoleClaim, "PhoneData");
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-telephone-fill"></i> Phone Data</h2>
    <div class="d-flex align-items-center gap-2">
        <span class="text-muted">@Model.Result.TotalCount.ToString("N0") records</span>
        <div class="dropdown">
            <button class="btn btn-outline-secondary btn-sm dropdown-toggle" type="button" id="colToggleBtn" data-bs-toggle="dropdown" aria-expanded="false">
                <i class="bi bi-layout-three-columns"></i> Columns
            </button>
            <ul class="dropdown-menu dropdown-menu-end p-2" id="colToggleMenu" style="min-width:200px;" onclick="event.stopPropagation()">
                <li><h6 class="dropdown-header">Toggle Columns</h6></li>
                <li><label class="dropdown-item"><input type="checkbox" class="col-toggle me-2" data-col="col-seq" checked> Seq</label></li>
                <li><label class="dropdown-item"><input type="checkbox" class="col-toggle me-2" data-col="col-status" checked> Status</label></li>
                <li><label class="dropdown-item"><input type="checkbox" class="col-toggle me-2" data-col="col-whatsapp" checked> WhatsApp</label></li>
                <li><label class="dropdown-item"><input type="checkbox" class="col-toggle me-2" data-col="col-remark" checked> Remark</label></li>
                <li><label class="dropdown-item"><input type="checkbox" class="col-toggle me-2" data-col="col-agent" checked> Agent Name</label></li>
                <li><label class="dropdown-item"><input type="checkbox" class="col-toggle me-2" data-col="col-reference" checked> Reference</label></li>
                <li><label class="dropdown-item"><input type="checkbox" class="col-toggle me-2" data-col="col-assigned" checked> Assigned To</label></li>
                <li><label class="dropdown-item"><input type="checkbox" class="col-toggle me-2" data-col="col-upload" checked> Upload Date</label></li>
                <li><label class="dropdown-item"><input type="checkbox" class="col-toggle me-2" data-col="col-modified" checked> Modified</label></li>
                <li><label class="dropdown-item"><input type="checkbox" class="col-toggle me-2" data-col="col-countweb" checked> Count Web</label></li>
                @if (isSuperadmin)
                {
                    <li><hr class="dropdown-divider"></li>
                    <li><h6 class="dropdown-header">Web Fields</h6></li>
                    for (int w = 1; w <= 10; w++)
                    {
                        <li><label class="dropdown-item"><input type="checkbox" class="col-toggle me-2" data-col="col-web@(w)"> web@(w)</label></li>
                    }
                }
            </ul>
        </div>
    </div>
</div>

<div class="card stat-card mb-4">
    <div class="card-body">
        <form method="get" class="row g-2 align-items-end" id="searchForm">
            <div class="col-md-3">
                <label class="form-label small">Phone Number</label>
                <input name="SearchPhoneNumber" value="@Model.SearchPhoneNumber" class="form-control" placeholder="Search phone number" />
            </div>
            <div class="col-md-2">
                <label class="form-label small">Status</label>
                <select name="Status" class="form-select">
                    <option value="">All Statuses</option>
                    @foreach (var s in PhoneStatuses.All)
                    {
                        <option value="@s" selected="@(Model.Status == s)">@s</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label small">WhatsApp Status</label>
                <input name="WhatsappStatus" value="@Model.WhatsappStatus" class="form-control" placeholder="Search WhatsApp status" />
            </div>
            <div class="col-md-3">
                <label class="form-label small">Remark</label>
                <input name="SearchRemark" value="@Model.SearchRemark" class="form-control" placeholder="Search remark" />
            </div>
            <div class="col-md-2">
                <label class="form-label small">Reference</label>
                <input name="SearchReference" value="@Model.SearchReference" class="form-control" placeholder="Search reference" />
            </div>
            <div class="col-md-2">
                <label class="form-label small">Agent Name</label>
                <input name="SearchAgentName" value="@Model.SearchAgentName" class="form-control" placeholder="Search agent name" />
            </div>
            <div class="col-md-2">
                <label class="form-label small">Date From</label>
                <input type="date" name="DateFrom" value="@dateFromStr" class="form-control" />
            </div>
            <div class="col-md-2">
                <label class="form-label small">Date To</label>
                <input type="date" name="DateTo" value="@dateToStr" class="form-control" />
            </div>
            <div class="col-md-2">
                <label class="form-label small">Per Page</label>
                <select name="PageSize" class="form-select">
                    @foreach (var ps in new[] { 20, 50, 100, 1000, 5000, 10000, 50000, 100000, 200000 })
                    {
                        <option value="@ps" selected="@(Model.PageSize == ps)">@ps.ToString("N0")</option>
                    }
                </select>
            </div>
            <div class="col-md-4">
                <input type="hidden" name="Page" value="1" />
                <button type="submit" class="btn btn-primary"><i class="bi bi-search"></i> Search</button>
                <a href="/PhoneNumbers" class="btn btn-outline-secondary">Clear</a>
                @if (canExport)
                {
                    <a href="#" id="exportSearchBtn" class="btn btn-success ms-1"><i class="bi bi-file-earmark-excel"></i> Export</a>
                    <a href="#" id="exportSplitBtn" class="btn btn-outline-success ms-1"><i class="bi bi-columns-gap"></i> Export Split</a>
                }
            </div>
        </form>
    </div>
</div>

@if (isAdminOrAbove && Model.Result.Items.Any())
{
    <div class="card mb-3 border-warning">
        <div class="card-body py-2">
            <div class="d-flex flex-wrap gap-2 align-items-center">
                <span class="text-muted small fw-bold" id="selectedCount">0 selected</span>
                <button type="button" class="btn btn-danger btn-sm" id="batchDeleteBtn" disabled
                        onclick="submitBatchDelete()">
                    <i class="bi bi-trash"></i> Delete Selected
                </button>
                <button type="button" class="btn btn-warning btn-sm fw-bold" id="batchUpdateBtn" disabled
                        data-bs-toggle="modal" data-bs-target="#batchUpdateModal">
                    <i class="bi bi-pencil-square"></i> Batch Update Selected
                </button>
                @if (isSuperadmin)
                {
                    <button type="button" class="btn btn-info btn-sm" id="assignBtn" disabled
                            data-bs-toggle="modal" data-bs-target="#assignModal">
                        <i class="bi bi-person-check"></i> Assign to User
                    </button>
                }
                <span class="text-muted small ms-2">Select rows using checkboxes below</span>
            </div>
        </div>
    </div>
}

<div class="card stat-card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0" id="phoneTable">
                <thead>
                    <tr>
                        @if (isAdminOrAbove)
                        {
                            <th style="width:40px">
                                <input type="checkbox" id="selectAll" class="form-check-input" title="Select All" />
                            </th>
                        }
                        <th>#</th>
                        <th class="col-seq">Seq</th>
                        <th>Phone Number</th>
                        <th class="col-status">Status</th>
                        <th class="col-whatsapp">WhatsApp</th>
                        <th class="col-remark">Remark</th>
                        <th class="col-agent">Agent Name</th>
                        <th class="col-reference">Reference</th>
                        <th class="col-assigned">Assigned To</th>
                        <th class="col-upload">Upload Date</th>
                        <th class="col-modified">Modified</th>
                        <th class="col-countweb">Count Web</th>
                        @if (isSuperadmin)
                        {
                            for (int w = 1; w <= 10; w++)
                            {
                                <th class="col-web@(w)" style="display:none">web@(w)</th>
                            }
                        }
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Result.Items.Any())
                    {
                        var idx = (Model.Page - 1) * Model.PageSize;
                        foreach (var item in Model.Result.Items)
                        {
                            idx++;
                            <tr>
                                @if (isAdminOrAbove)
                                {
                                    <td>
                                        <input type="checkbox" class="form-check-input row-check" value="@item.Id" />
                                    </td>
                                }
                                <td class="text-muted">@idx</td>
                                <td class="col-seq">@item.Seq</td>
                                <td><code>@item.PhoneNumber</code></td>
                                <td class="col-status">
                                    <span class="badge @(item.Status == "active" ? "bg-success" : "bg-secondary")">@item.Status</span>
                                </td>
                                <td class="col-whatsapp">
                                    @if (!string.IsNullOrEmpty(item.WhatsappStatus))
                                    {
                                        <span class="badge bg-info text-dark">@item.WhatsappStatus</span>
                                    }
                                </td>
                                <td class="col-remark">@(item.Remark != null && item.Remark.Length > 30 ? item.Remark[..30] + "..." : item.Remark)</td>
                                <td class="col-agent">@item.AgentName</td>
                                <td class="col-reference">@item.Reference</td>
                                <td class="col-assigned">@(item.AssignedUserName ?? "")</td>
                                <td class="col-upload text-muted small">@item.UploadDate.ToJakartaDisplay()</td>
                                <td class="col-modified text-muted small">@item.ModifiedDate.ToJakartaDisplay()</td>
                                <td class="col-countweb">
                                    @if (item.CountWeb > 0)
                                    {
                                        <span class="badge bg-primary">@item.CountWeb</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">0</span>
                                    }
                                </td>
                                @if (isSuperadmin)
                                {
                                    var webVals = new[] { item.Web1, item.Web2, item.Web3, item.Web4, item.Web5, item.Web6, item.Web7, item.Web8, item.Web9, item.Web10 };
                                    for (int w = 1; w <= 10; w++)
                                    {
                                        var val = webVals[w - 1];
                                        <td class="col-web@(w)" style="display:none">
                                            @if (val?.Equals("YES", StringComparison.OrdinalIgnoreCase) == true)
                                            {
                                                <span class="badge bg-success">YES</span>
                                            }
                                            else if (val?.Equals("NO", StringComparison.OrdinalIgnoreCase) == true)
                                            {
                                                <span class="badge bg-secondary">NO</span>
                                            }
                                        </td>
                                    }
                                }
                                <td>
                                    <a href="/PhoneNumbers/Edit/@item.Id" class="btn btn-outline-primary btn-sm">
                                        <i class="bi bi-pencil"></i> Edit
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        var colCount = (isAdminOrAbove ? 1 : 0) + 11 + (isSuperadmin ? 10 : 0);
                        <tr><td colspan="@colCount" class="text-center text-muted py-4">No records found.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (totalPages > 1 || Model.Result.TotalCount > 0)
{
    <div class="mt-3">
        <div class="d-flex justify-content-center align-items-center gap-2 flex-wrap">
            <span class="text-muted small me-2">Page @Model.Page of @totalPages</span>
            <nav>
                <ul class="pagination mb-0">
                    @if (Model.Page > 1)
                    {
                        <li class="page-item">
                            <a class="page-link" href="/PhoneNumbers?SearchPhoneNumber=@Model.SearchPhoneNumber&Status=@Model.Status&WhatsappStatus=@Model.WhatsappStatus&SearchRemark=@Model.SearchRemark&SearchReference=@searchRef&SearchAgentName=@searchAgent&DateFrom=@dateFromStr&DateTo=@dateToStr&Page=1&PageSize=@Model.PageSize" title="First">&laquo;&laquo;</a>
                        </li>
                        <li class="page-item">
                            <a class="page-link" href="/PhoneNumbers?SearchPhoneNumber=@Model.SearchPhoneNumber&Status=@Model.Status&WhatsappStatus=@Model.WhatsappStatus&SearchRemark=@Model.SearchRemark&SearchReference=@searchRef&SearchAgentName=@searchAgent&DateFrom=@dateFromStr&DateTo=@dateToStr&Page=@(Model.Page - 1)&PageSize=@Model.PageSize">&laquo; Prev</a>
                        </li>
                    }
                    @for (int i = Math.Max(1, Model.Page - 2); i <= Math.Min(totalPages, Model.Page + 2); i++)
                    {
                        <li class="page-item @(i == Model.Page ? "active" : "")">
                            <a class="page-link" href="/PhoneNumbers?SearchPhoneNumber=@Model.SearchPhoneNumber&Status=@Model.Status&WhatsappStatus=@Model.WhatsappStatus&SearchRemark=@Model.SearchRemark&SearchReference=@searchRef&SearchAgentName=@searchAgent&DateFrom=@dateFromStr&DateTo=@dateToStr&Page=@i&PageSize=@Model.PageSize">@i</a>
                        </li>
                    }
                    @if (Model.Page < totalPages)
                    {
                        <li class="page-item">
                            <a class="page-link" href="/PhoneNumbers?SearchPhoneNumber=@Model.SearchPhoneNumber&Status=@Model.Status&WhatsappStatus=@Model.WhatsappStatus&SearchRemark=@Model.SearchRemark&SearchReference=@searchRef&SearchAgentName=@searchAgent&DateFrom=@dateFromStr&DateTo=@dateToStr&Page=@(Model.Page + 1)&PageSize=@Model.PageSize">Next &raquo;</a>
                        </li>
                        <li class="page-item">
                            <a class="page-link" href="/PhoneNumbers?SearchPhoneNumber=@Model.SearchPhoneNumber&Status=@Model.Status&WhatsappStatus=@Model.WhatsappStatus&SearchRemark=@Model.SearchRemark&SearchReference=@searchRef&SearchAgentName=@searchAgent&DateFrom=@dateFromStr&DateTo=@dateToStr&Page=@totalPages&PageSize=@Model.PageSize" title="Last">&raquo;&raquo;</a>
                        </li>
                    }
                </ul>
            </nav>
            <div class="d-flex align-items-center gap-1 ms-2">
                <span class="text-muted small">Go to:</span>
                <input type="number" id="goToPageInput" class="form-control form-control-sm" style="width:70px"
                       min="1" max="@totalPages" placeholder="@Model.Page" />
                <button type="button" class="btn btn-outline-secondary btn-sm" onclick="goToPage()">Go</button>
            </div>
        </div>
    </div>
}

@if (isAdminOrAbove)
{
    <form method="post" asp-action="BatchDelete" id="batchDeleteForm" style="display:none">
        @Html.AntiForgeryToken()
        <div id="batchDeleteIds"></div>
    </form>

    <div class="modal fade" id="batchUpdateModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <form method="post" asp-action="BatchUpdate" id="batchUpdateForm">
                    @Html.AntiForgeryToken()
                    <div id="batchUpdateIds"></div>
                    <div class="modal-header bg-warning bg-opacity-25">
                        <h5 class="modal-title"><i class="bi bi-pencil-square"></i> Batch Update</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <div class="alert alert-info py-2">
                            <i class="bi bi-info-circle"></i> Updating <strong id="batchUpdateCount">0</strong> selected record(s).
                            Leave a field blank to keep existing value.
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Status</label>
                            <select name="Status" class="form-select">
                                <option value="">-- Keep existing --</option>
                                @foreach (var s in PhoneStatuses.All)
                                {
                                    <option value="@s">@s</option>
                                }
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">WhatsApp Status</label>
                            <select name="WhatsappStatus" class="form-select">
                                <option value="">-- Keep existing --</option>
                                @foreach (var s in WhatsappStatuses.All)
                                {
                                    <option value="@s">@s</option>
                                }
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Agent Name</label>
                            <input type="text" name="AgentName" class="form-control" placeholder="-- Keep existing --" maxlength="100" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Remark</label>
                            <input type="text" name="Remark" class="form-control" placeholder="-- Keep existing --" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Reference</label>
                            <input type="text" name="Reference" class="form-control" placeholder="-- Keep existing --" maxlength="255" />
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-warning fw-bold"><i class="bi bi-pencil-square"></i> Update Selected</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    @if (isSuperadmin)
    {
        @* Assign to User Modal *@
        <div class="modal fade" id="assignModal" tabindex="-1">
            <div class="modal-dialog">
                <div class="modal-content">
                    <form method="post" asp-action="AssignToUser" id="assignForm">
                        @Html.AntiForgeryToken()
                        <div id="assignIds"></div>
                        <div class="modal-header">
                            <h5 class="modal-title"><i class="bi bi-person-check"></i> Assign to User</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                        </div>
                        <div class="modal-body">
                            <p class="text-muted small mb-3">Assign <strong id="assignCount">0</strong> record(s) to a user.</p>
                            <div class="mb-3">
                                <label class="form-label">Assign to</label>
                                <select name="assignedUserId" class="form-select">
                                    <option value="">-- Unassign (remove assignment) --</option>
                                    @foreach (var u in Model.Users)
                                    {
                                        <option value="@u.Id">@u.FullName (@u.Email)</option>
                                    }
                                </select>
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                            <button type="submit" class="btn btn-info"><i class="bi bi-person-check"></i> Assign</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    }
}

@section Scripts {
    <script>
        // Column visibility with localStorage persistence
        const STORAGE_KEY = 'phoneColVisibility';

        function getColPrefs() {
            try { return JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}'); } catch { return {}; }
        }

        function saveColPref(col, visible) {
            var prefs = getColPrefs();
            prefs[col] = visible;
            localStorage.setItem(STORAGE_KEY, JSON.stringify(prefs));
        }

        function applyColVisibility(col, visible) {
            var cells = document.querySelectorAll('.' + col);
            cells.forEach(function (cell) {
                cell.style.display = visible ? '' : 'none';
            });
        }

        document.addEventListener('DOMContentLoaded', function () {
            var prefs = getColPrefs();
            document.querySelectorAll('.col-toggle').forEach(function (cb) {
                var col = cb.dataset.col;
                // Default: web columns hidden, others shown
                var defaultVisible = !col.startsWith('col-web');
                var visible = prefs.hasOwnProperty(col) ? prefs[col] : defaultVisible;
                cb.checked = visible;
                applyColVisibility(col, visible);

                cb.addEventListener('change', function () {
                    saveColPref(col, this.checked);
                    applyColVisibility(col, this.checked);
                });
            });
        });

        // Export
        document.getElementById('exportSearchBtn')?.addEventListener('click', function (e) {
            e.preventDefault();
            var form = document.getElementById('searchForm');
            var params = new URLSearchParams(new FormData(form));
            params.delete('Page');
            window.location.href = '/PhoneNumbers/ExportSearch?' + params.toString();
        });

        // Go to page
        function goToPage() {
            var input = document.getElementById('goToPageInput');
            var page = parseInt(input.value);
            if (isNaN(page) || page < 1) page = 1;
            if (page > @totalPages) page = @totalPages;
            var form = document.getElementById('searchForm');
            var params = new URLSearchParams(new FormData(form));
            params.set('Page', page);
            window.location.href = '/PhoneNumbers?' + params.toString();
            // Note: FormData from the search form already includes SearchReference and SearchAgentName
        }

        document.getElementById('goToPageInput')?.addEventListener('keydown', function(e) {
            if (e.key === 'Enter') { e.preventDefault(); goToPage(); }
        });
    </script>
    @if (isAdminOrAbove)
    {
        <script>
            var selectedIds = new Set();

            function updateBatchButtons() {
                var count = selectedIds.size;
                document.getElementById('selectedCount').textContent = count + ' selected';
                document.getElementById('batchDeleteBtn').disabled = count === 0;
                document.getElementById('batchUpdateBtn').disabled = count === 0;
                var assignBtn = document.getElementById('assignBtn');
                if (assignBtn) assignBtn.disabled = count === 0;
                var countEl = document.getElementById('batchUpdateCount');
                if (countEl) countEl.textContent = count;
            }

            document.querySelectorAll('.row-check').forEach(function (cb) {
                cb.addEventListener('change', function () {
                    if (this.checked) selectedIds.add(this.value);
                    else selectedIds.delete(this.value);
                    updateBatchButtons();
                });
            });

            document.getElementById('selectAll').addEventListener('change', function () {
                var checked = this.checked;
                document.querySelectorAll('.row-check').forEach(function (cb) {
                    cb.checked = checked;
                    if (checked) selectedIds.add(cb.value);
                    else selectedIds.delete(cb.value);
                });
                updateBatchButtons();
            });

            function submitBatchDelete() {
                if (selectedIds.size === 0) return;
                if (!confirm('Delete ' + selectedIds.size + ' selected record(s)? This cannot be undone.')) return;
                var form = document.getElementById('batchDeleteForm');
                var container = document.getElementById('batchDeleteIds');
                container.innerHTML = '';
                selectedIds.forEach(function (id) {
                    var input = document.createElement('input');
                    input.type = 'hidden';
                    input.name = 'selectedIds';
                    input.value = id;
                    container.appendChild(input);
                });
                form.submit();
            }

            document.getElementById('batchUpdateModal').addEventListener('show.bs.modal', function () {
                var container = document.getElementById('batchUpdateIds');
                container.innerHTML = '';
                selectedIds.forEach(function (id) {
                    var input = document.createElement('input');
                    input.type = 'hidden';
                    input.name = 'SelectedIds';
                    input.value = id;
                    container.appendChild(input);
                });
                document.getElementById('batchUpdateCount').textContent = selectedIds.size;
            });

            @if (isSuperadmin)
            {
                <text>
                document.getElementById('assignModal')?.addEventListener('show.bs.modal', function () {
                    var container = document.getElementById('assignIds');
                    container.innerHTML = '';
                    selectedIds.forEach(function (id) {
                        var input = document.createElement('input');
                        input.type = 'hidden';
                        input.name = 'selectedIds';
                        input.value = id;
                        container.appendChild(input);
                    });
                    document.getElementById('assignCount').textContent = selectedIds.size;
                });
                </text>
            }

            // Export Split
            document.getElementById('exportSplitBtn')?.addEventListener('click', function (e) {
                e.preventDefault();
                var params = new URLSearchParams(new FormData(document.querySelector('form')));
                params.delete('Page');
                window.location.href = '/PhoneNumbers/ExportSplit?' + params.toString();
            });
        </script>
    }
}
