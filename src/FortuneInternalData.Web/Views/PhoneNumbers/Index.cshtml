@model FortuneInternalData.Web.ViewModels.PhoneNumberListViewModel
@using FortuneInternalData.Domain.Constants
@using FortuneInternalData.Web.Extensions
@using Microsoft.AspNetCore.Authorization
@inject IAuthorizationService AuthorizationService
@inject FortuneInternalData.Application.Interfaces.IPermissionService PermissionService
@{
    ViewData["Title"] = "Phone Data";
    var totalPages = Model.Result.TotalCount > 0 ? (int)Math.Ceiling((double)Model.Result.TotalCount / Model.PageSize) : 1;
    var isAdminOrAbove = (await AuthorizationService.AuthorizeAsync(User, FortuneInternalData.Web.Security.PolicyNames.AdminOrAbove)).Succeeded;
    var dateFromStr = Model.DateFrom.HasValue ? Model.DateFrom.Value.ToString("yyyy-MM-dd") : "";
    var dateToStr = Model.DateTo.HasValue ? Model.DateTo.Value.ToString("yyyy-MM-dd") : "";

    var userRoleClaim = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? string.Empty;
    var canExport = await PermissionService.HasExportPermissionAsync(userRoleClaim, "PhoneData");
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-telephone-fill"></i> Phone Data</h2>
    <span class="text-muted">@Model.Result.TotalCount.ToString("N0") records</span>
</div>

<div class="card stat-card mb-4">
    <div class="card-body">
        <form method="get" class="row g-2 align-items-end" id="searchForm">
            <div class="col-md-3">
                <label class="form-label small">Phone Number</label>
                <input name="SearchPhoneNumber" value="@Model.SearchPhoneNumber" class="form-control" placeholder="Search phone number" />
            </div>
            <div class="col-md-2">
                <label class="form-label small">Status</label>
                <select name="Status" class="form-select">
                    <option value="">All Statuses</option>
                    @foreach (var s in PhoneStatuses.All)
                    {
                        <option value="@s" selected="@(Model.Status == s)">@s</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label small">WhatsApp Status</label>
                <input name="WhatsappStatus" value="@Model.WhatsappStatus" class="form-control" placeholder="Search WhatsApp status" />
            </div>
            <div class="col-md-3">
                <label class="form-label small">Remark</label>
                <input name="SearchRemark" value="@Model.SearchRemark" class="form-control" placeholder="Search remark" />
            </div>
            <div class="col-md-2">
                <label class="form-label small">Date From</label>
                <input type="date" name="DateFrom" value="@dateFromStr" class="form-control" />
            </div>
            <div class="col-md-2">
                <label class="form-label small">Date To</label>
                <input type="date" name="DateTo" value="@dateToStr" class="form-control" />
            </div>
            <div class="col-md-2">
                <label class="form-label small">Per Page</label>
                <select name="PageSize" class="form-select">
                    @foreach (var ps in new[] { 20, 50, 100, 1000, 5000, 10000, 50000, 100000, 200000 })
                    {
                        <option value="@ps" selected="@(Model.PageSize == ps)">@ps.ToString("N0")</option>
                    }
                </select>
            </div>
            <div class="col-md-4">
                <input type="hidden" name="Page" value="1" />
                <button type="submit" class="btn btn-primary"><i class="bi bi-search"></i> Search</button>
                <a href="/PhoneNumbers" class="btn btn-outline-secondary">Clear</a>
                @if (canExport)
                {
                    <a href="#" id="exportSearchBtn" class="btn btn-success ms-1"><i class="bi bi-file-earmark-excel"></i> Export</a>
                }
            </div>
        </form>
    </div>
</div>

@if (isAdminOrAbove && Model.Result.Items.Any())
{
    <div class="card mb-3 border-warning">
        <div class="card-body py-2">
            <div class="d-flex flex-wrap gap-2 align-items-center">
                <span class="text-muted small fw-bold" id="selectedCount">0 selected</span>
                <button type="button" class="btn btn-danger btn-sm" id="batchDeleteBtn" disabled
                        onclick="submitBatchDelete()">
                    <i class="bi bi-trash"></i> Delete Selected
                </button>
                <button type="button" class="btn btn-warning btn-sm fw-bold" id="batchUpdateBtn" disabled
                        data-bs-toggle="modal" data-bs-target="#batchUpdateModal">
                    <i class="bi bi-pencil-square"></i> Batch Update Selected
                </button>
                <span class="text-muted small ms-2">Select rows using checkboxes below</span>
            </div>
        </div>
    </div>
}

<div class="card stat-card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0" id="phoneTable">
                <thead>
                    <tr>
                        @if (isAdminOrAbove)
                        {
                            <th style="width:40px">
                                <input type="checkbox" id="selectAll" class="form-check-input" title="Select All" />
                            </th>
                        }
                        <th>#</th>
                        <th>Seq</th>
                        <th>Phone Number</th>
                        <th>Status</th>
                        <th>WhatsApp</th>
                        <th>Remark</th>
                        <th>Agent Name</th>
                        <th>Reference</th>
                        <th>Upload Date</th>
                        <th>Modified</th>
                        <th>Action</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Result.Items.Any())
                    {
                        var idx = (Model.Page - 1) * Model.PageSize;
                        foreach (var item in Model.Result.Items)
                        {
                            idx++;
                            <tr>
                                @if (isAdminOrAbove)
                                {
                                    <td>
                                        <input type="checkbox" class="form-check-input row-check" value="@item.Id" />
                                    </td>
                                }
                                <td class="text-muted">@idx</td>
                                <td>@item.Seq</td>
                                <td><code>@item.PhoneNumber</code></td>
                                <td>
                                    <span class="badge @(item.Status == "active" ? "bg-success" : "bg-secondary")">@item.Status</span>
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(item.WhatsappStatus))
                                    {
                                        <span class="badge bg-info text-dark">@item.WhatsappStatus</span>
                                    }
                                </td>
                                <td>@(item.Remark != null && item.Remark.Length > 30 ? item.Remark[..30] + "..." : item.Remark)</td>
                                <td>@item.AgentName</td>
                                <td>@item.Reference</td>
                                <td class="text-muted small">@item.UploadDate.ToJakartaDisplay()</td>
                                <td class="text-muted small">@item.ModifiedDate.ToJakartaDisplay()</td>
                                <td>
                                    <a href="/PhoneNumbers/Edit/@item.Id" class="btn btn-outline-primary btn-sm">
                                        <i class="bi bi-pencil"></i> Edit
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr><td colspan="@(isAdminOrAbove ? 12 : 11)" class="text-center text-muted py-4">No records found.</td></tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (totalPages > 1 || Model.Result.TotalCount > 0)
{
    <div class="mt-3">
        <div class="d-flex justify-content-center align-items-center gap-2 flex-wrap">
            <span class="text-muted small me-2">Page @Model.Page of @totalPages</span>
            <nav>
                <ul class="pagination mb-0">
                    @* First page *@
                    @if (Model.Page > 1)
                    {
                        <li class="page-item">
                            <a class="page-link" href="/PhoneNumbers?SearchPhoneNumber=@Model.SearchPhoneNumber&Status=@Model.Status&WhatsappStatus=@Model.WhatsappStatus&SearchRemark=@Model.SearchRemark&DateFrom=@dateFromStr&DateTo=@dateToStr&Page=1&PageSize=@Model.PageSize" title="First">&laquo;&laquo;</a>
                        </li>
                        <li class="page-item">
                            <a class="page-link" href="/PhoneNumbers?SearchPhoneNumber=@Model.SearchPhoneNumber&Status=@Model.Status&WhatsappStatus=@Model.WhatsappStatus&SearchRemark=@Model.SearchRemark&DateFrom=@dateFromStr&DateTo=@dateToStr&Page=@(Model.Page - 1)&PageSize=@Model.PageSize">&laquo; Prev</a>
                        </li>
                    }
                    @for (int i = Math.Max(1, Model.Page - 2); i <= Math.Min(totalPages, Model.Page + 2); i++)
                    {
                        <li class="page-item @(i == Model.Page ? "active" : "")">
                            <a class="page-link" href="/PhoneNumbers?SearchPhoneNumber=@Model.SearchPhoneNumber&Status=@Model.Status&WhatsappStatus=@Model.WhatsappStatus&SearchRemark=@Model.SearchRemark&DateFrom=@dateFromStr&DateTo=@dateToStr&Page=@i&PageSize=@Model.PageSize">@i</a>
                        </li>
                    }
                    @if (Model.Page < totalPages)
                    {
                        <li class="page-item">
                            <a class="page-link" href="/PhoneNumbers?SearchPhoneNumber=@Model.SearchPhoneNumber&Status=@Model.Status&WhatsappStatus=@Model.WhatsappStatus&SearchRemark=@Model.SearchRemark&DateFrom=@dateFromStr&DateTo=@dateToStr&Page=@(Model.Page + 1)&PageSize=@Model.PageSize">Next &raquo;</a>
                        </li>
                        <li class="page-item">
                            <a class="page-link" href="/PhoneNumbers?SearchPhoneNumber=@Model.SearchPhoneNumber&Status=@Model.Status&WhatsappStatus=@Model.WhatsappStatus&SearchRemark=@Model.SearchRemark&DateFrom=@dateFromStr&DateTo=@dateToStr&Page=@totalPages&PageSize=@Model.PageSize" title="Last">&raquo;&raquo;</a>
                        </li>
                    }
                </ul>
            </nav>
            @* Go to page *@
            <div class="d-flex align-items-center gap-1 ms-2">
                <span class="text-muted small">Go to:</span>
                <input type="number" id="goToPageInput" class="form-control form-control-sm" style="width:70px"
                       min="1" max="@totalPages" placeholder="@Model.Page" />
                <button type="button" class="btn btn-outline-secondary btn-sm" onclick="goToPage()">Go</button>
            </div>
        </div>
    </div>
}

@if (isAdminOrAbove)
{
    @* Batch Delete hidden form *@
    <form method="post" asp-action="BatchDelete" id="batchDeleteForm" style="display:none">
        @Html.AntiForgeryToken()
        <div id="batchDeleteIds"></div>
    </form>

    @* Batch Update Modal *@
    <div class="modal fade" id="batchUpdateModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <form method="post" asp-action="BatchUpdate" id="batchUpdateForm">
                    @Html.AntiForgeryToken()
                    <div id="batchUpdateIds"></div>
                    <div class="modal-header bg-warning bg-opacity-25">
                        <h5 class="modal-title"><i class="bi bi-pencil-square"></i> Batch Update</h5>
                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <div class="alert alert-info py-2">
                            <i class="bi bi-info-circle"></i> Updating <strong id="batchUpdateCount">0</strong> selected record(s).
                            Leave a field blank to keep existing value.
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Status</label>
                            <select name="Status" class="form-select">
                                <option value="">-- Keep existing --</option>
                                @foreach (var s in PhoneStatuses.All)
                                {
                                    <option value="@s">@s</option>
                                }
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">WhatsApp Status</label>
                            <select name="WhatsappStatus" class="form-select">
                                <option value="">-- Keep existing --</option>
                                @foreach (var s in WhatsappStatuses.All)
                                {
                                    <option value="@s">@s</option>
                                }
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Agent Name</label>
                            <input type="text" name="AgentName" class="form-control" placeholder="-- Keep existing --" maxlength="100" />
                            <div class="form-text">Set agent name for all selected records</div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Remark</label>
                            <input type="text" name="Remark" class="form-control" placeholder="-- Keep existing --" />
                            <div class="form-text">Set remark for all selected records</div>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-semibold">Reference</label>
                            <input type="text" name="Reference" class="form-control" placeholder="-- Keep existing --" maxlength="255" />
                            <div class="form-text">Set reference for all selected records</div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-warning fw-bold"><i class="bi bi-pencil-square"></i> Update Selected</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
        // Build export URL from current search form
        document.getElementById('exportSearchBtn')?.addEventListener('click', function (e) {
            e.preventDefault();
            var form = document.getElementById('searchForm');
            var params = new URLSearchParams(new FormData(form));
            params.delete('Page');
            window.location.href = '/PhoneNumbers/ExportSearch?' + params.toString();
        });

        // Go to page
        function goToPage() {
            var input = document.getElementById('goToPageInput');
            var page = parseInt(input.value);
            if (isNaN(page) || page < 1) page = 1;
            if (page > @totalPages) page = @totalPages;
            var form = document.getElementById('searchForm');
            var params = new URLSearchParams(new FormData(form));
            params.set('Page', page);
            window.location.href = '/PhoneNumbers?' + params.toString();
        }

        document.getElementById('goToPageInput')?.addEventListener('keydown', function(e) {
            if (e.key === 'Enter') { e.preventDefault(); goToPage(); }
        });
    </script>
    @if (isAdminOrAbove)
    {
        <script>
            var selectedIds = new Set();

            function updateBatchButtons() {
                var count = selectedIds.size;
                document.getElementById('selectedCount').textContent = count + ' selected';
                document.getElementById('batchDeleteBtn').disabled = count === 0;
                document.getElementById('batchUpdateBtn').disabled = count === 0;
                var countEl = document.getElementById('batchUpdateCount');
                if (countEl) countEl.textContent = count;
            }

            document.querySelectorAll('.row-check').forEach(function (cb) {
                cb.addEventListener('change', function () {
                    if (this.checked) {
                        selectedIds.add(this.value);
                    } else {
                        selectedIds.delete(this.value);
                    }
                    updateBatchButtons();
                });
            });

            document.getElementById('selectAll').addEventListener('change', function () {
                var checked = this.checked;
                document.querySelectorAll('.row-check').forEach(function (cb) {
                    cb.checked = checked;
                    if (checked) {
                        selectedIds.add(cb.value);
                    } else {
                        selectedIds.delete(cb.value);
                    }
                });
                updateBatchButtons();
            });

            function submitBatchDelete() {
                if (selectedIds.size === 0) return;
                if (!confirm('Delete ' + selectedIds.size + ' selected record(s)? This cannot be undone.')) return;

                var form = document.getElementById('batchDeleteForm');
                var container = document.getElementById('batchDeleteIds');
                container.innerHTML = '';
                selectedIds.forEach(function (id) {
                    var input = document.createElement('input');
                    input.type = 'hidden';
                    input.name = 'selectedIds';
                    input.value = id;
                    container.appendChild(input);
                });
                form.submit();
            }

            document.getElementById('batchUpdateModal').addEventListener('show.bs.modal', function () {
                var container = document.getElementById('batchUpdateIds');
                container.innerHTML = '';
                selectedIds.forEach(function (id) {
                    var input = document.createElement('input');
                    input.type = 'hidden';
                    input.name = 'SelectedIds';
                    input.value = id;
                    container.appendChild(input);
                });
                document.getElementById('batchUpdateCount').textContent = selectedIds.size;
            });
        </script>
    }
}
