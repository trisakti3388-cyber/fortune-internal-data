@model FortuneInternalData.Web.ViewModels.PhoneNumberEditViewModel
@using FortuneInternalData.Domain.Constants
@using FortuneInternalData.Web.Extensions
@{
    ViewData["Title"] = "Edit Phone Record";
    var isSuperadmin = User.IsInRole("Superadmin");
}

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <div class="card stat-card">
            <div class="card-header bg-white">
                <h4 class="mb-0"><i class="bi bi-pencil-square"></i> Edit Phone Record</h4>
            </div>
            <div class="card-body p-4">
                <div class="mb-3 p-3 bg-light rounded">
                    <label class="form-label text-muted small">Phone Number</label>
                    <div class="fs-4 font-monospace">@Model.PhoneNumber</div>
                </div>

                <form method="post" asp-action="Edit">
                    <div asp-validation-summary="All" class="alert alert-danger" style="display: @(ViewData.ModelState.ErrorCount > 0 ? "block" : "none")"></div>
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="PhoneNumber" />

                    <div class="mb-3">
                        <label asp-for="Status" class="form-label">Status</label>
                        <select asp-for="Status" class="form-select">
                            @foreach (var s in PhoneStatuses.All)
                            {
                                <option value="@s">@s</option>
                            }
                        </select>
                        <span asp-validation-for="Status" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="WhatsappStatus" class="form-label">WhatsApp Status</label>
                        <select asp-for="WhatsappStatus" class="form-select">
                            <option value="">-- Not Set --</option>
                            @foreach (var s in WhatsappStatuses.All)
                            {
                                <option value="@s">@s</option>
                            }
                        </select>
                    </div>

                    <div class="mb-3">
                        <label asp-for="AgentName" class="form-label">Agent Name</label>
                        <input asp-for="AgentName" class="form-control" placeholder="Agent name (optional)" maxlength="100" />
                        <span asp-validation-for="AgentName" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Reference" class="form-label">Reference</label>
                        <input asp-for="Reference" class="form-control" placeholder="Reference (optional)" maxlength="255" />
                        <span asp-validation-for="Reference" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Remark" class="form-label">Remark</label>
                        <textarea asp-for="Remark" class="form-control" rows="3"></textarea>
                        <span asp-validation-for="Remark" class="text-danger small"></span>
                    </div>

                    @if (isSuperadmin)
                    {
                        <hr />
                        <h6 class="text-muted mb-3"><i class="bi bi-globe"></i> Web Status Fields</h6>
                        <div class="row g-2">
                            @{
                                var webNames = new[] { "Web1","Web2","Web3","Web4","Web5","Web6","Web7","Web8","Web9","Web10" };
                                var webVals = new[] { Model.Web1, Model.Web2, Model.Web3, Model.Web4, Model.Web5, Model.Web6, Model.Web7, Model.Web8, Model.Web9, Model.Web10 };
                            }
                            @for (int w = 0; w < 10; w++)
                            {
                                <div class="col-6 col-md-4 col-lg-3">
                                    <label class="form-label small fw-semibold">web@(w+1)</label>
                                    <select name="@webNames[w]" class="form-select form-select-sm">
                                        <option value="" selected="@(string.IsNullOrEmpty(webVals[w]))">-- Not Set --</option>
                                        <option value="YES" selected="@(webVals[w]?.Equals("YES", StringComparison.OrdinalIgnoreCase) == true)">YES</option>
                                        <option value="NO" selected="@(webVals[w]?.Equals("NO", StringComparison.OrdinalIgnoreCase) == true)">NO</option>
                                    </select>
                                </div>
                            }
                        </div>
                    }

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check-lg"></i> Save Changes
                        </button>
                        <a href="/PhoneNumbers" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
