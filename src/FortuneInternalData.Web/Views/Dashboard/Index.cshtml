@model FortuneInternalData.Application.DTOs.DashboardSummaryDto
@{
    ViewData["Title"] = "Dashboard";
    var recentBatches = ViewBag.RecentBatches as List<FortuneInternalData.Application.DTOs.ImportBatchListItemDto> ?? new();
}

<h2 class="mb-4"><i class="bi bi-speedometer2"></i> Dashboard</h2>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card stat-card">
            <div class="card-body">
                <div class="text-muted small">Total Phone Data</div>
                <div class="stat-value text-primary">@Model.TotalPhoneData.ToString("N0")</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card stat-card">
            <div class="card-body">
                <div class="text-muted small">Active</div>
                <div class="stat-value text-success">@Model.ActiveCount.ToString("N0")</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card stat-card">
            <div class="card-body">
                <div class="text-muted small">Inactive</div>
                <div class="stat-value text-secondary">@Model.InactiveCount.ToString("N0")</div>
            </div>
        </div>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col">
        <div class="card stat-card">
            <div class="card-header bg-white"><h5 class="mb-0">WhatsApp Status Breakdown</h5></div>
            <div class="card-body">
                <div class="row text-center">
                    <div class="col">
                        <div class="fw-bold fs-4 text-info">@Model.Whatsapp1DayCount.ToString("N0")</div>
                        <div class="text-muted small">1 Day</div>
                    </div>
                    <div class="col">
                        <div class="fw-bold fs-4 text-info">@Model.Whatsapp3DayCount.ToString("N0")</div>
                        <div class="text-muted small">3 Day</div>
                    </div>
                    <div class="col">
                        <div class="fw-bold fs-4 text-info">@Model.Whatsapp7DayCount.ToString("N0")</div>
                        <div class="text-muted small">7 Day</div>
                    </div>
                    <div class="col">
                        <div class="fw-bold fs-4 text-success">@Model.WhatsappActiveCount.ToString("N0")</div>
                        <div class="text-muted small">Active</div>
                    </div>
                    <div class="col">
                        <div class="fw-bold fs-4 text-secondary">@Model.WhatsappInactiveCount.ToString("N0")</div>
                        <div class="text-muted small">Inactive</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@if (recentBatches.Any())
{
    <div class="card stat-card">
        <div class="card-header bg-white d-flex justify-content-between align-items-center">
            <h5 class="mb-0">Recent Imports</h5>
            <a href="/Imports" class="btn btn-outline-primary btn-sm">View All</a>
        </div>
        <div class="card-body p-0">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>File</th>
                        <th>Uploaded By</th>
                        <th>Status</th>
                        <th>New</th>
                        <th>Total</th>
                        <th>Date</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var batch in recentBatches)
                    {
                        <tr>
                            <td>@batch.FileName</td>
                            <td>@batch.UploadedByName</td>
                            <td><span class="badge badge-@batch.Status">@batch.Status</span></td>
                            <td>@batch.NewRows</td>
                            <td>@batch.TotalRows</td>
                            <td>@batch.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}
