@model FortuneInternalData.Web.ViewModels.CreateUserViewModel

<div class="card">
    <h2>Create User</h2>
    <form method="post">
        <div>
            <label>Name</label><br />
            <input asp-for="Name" />
        </div>
        <div>
            <label>Email</label><br />
            <input asp-for="Email" />
        </div>
        <div>
            <label>Role</label><br />
            <input asp-for="Role" />
        </div>
        <div>
            <label>Password</label><br />
            <input asp-for="Password" type="password" />
        </div>
        <button type="submit">Create User</button>
    </form>
</div>
